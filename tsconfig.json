{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "isolatedModules": true,
    "paths": {
      "@vsi/db": ["./packages/db/src/index.ts"],
      "@vsi/auth": ["./packages/auth/src/index.ts"]
    }
  },
  "include": ["scripts/**/*"]
}
